generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ────────────────────────────────────────────────────────────────

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  active      Boolean   @default(true)
  variants    Variant[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Variant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  color     String
  size      String
  price     Int // price in HUF (forint), stored as integer — no decimals
  stock     Int      @default(0)
  orders    Order[]
}

model Clipart {
  id        String   @id @default(cuid())
  name      String
  category  String
  svgUrl    String   // Supabase Storage public URL (clipart bucket — permanent)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Design {
  id         String   @id @default(cuid())
  canvasJson Json // Fabric.js serialized canvas state — stored as JSONB
  svgUrl     String? // S3 URL of the exported SVG, nulled after 45 days
  createdAt  DateTime @default(now())
  expiresAt  DateTime // set to createdAt + 45 days at creation time
  order      Order?
}

model Order {
  id              String      @id @default(cuid())
  stripeSessionId String      @unique
  status          OrderStatus @default(PENDING)
  // Product
  variantId       String
  variant         Variant     @relation(fields: [variantId], references: [id])
  // Design (optional — not all products require a custom design)
  designId        String?     @unique
  design          Design?     @relation(fields: [designId], references: [id])
  // Customer info — retained 8 years per Hungarian tax law (Számviteli törvény)
  customerName    String
  customerEmail   String
  shippingAddress Json // { street, city, zip, country }
  totalAmount     Int // in HUF
  gdprConsent     Boolean
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING // Stripe session created, payment not yet confirmed
  PAID // Stripe webhook received — order is now real
  IN_PRODUCTION // Admin has started processing
  SHIPPED // Package sent
  COMPLETE // Delivered
  CANCELLED // Cancelled before or after production
}
