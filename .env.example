# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# DATABASE_URL: Transaction pooler (port 6543) — used by the app at runtime.
# Find in: Supabase → Connect → Transaction pooler URL
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# DIRECT_URL: Direct connection (port 5432) — used by Prisma CLI for migrations.
# Find in: Supabase → Connect → Direct connection URL
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Service role key for server-side storage operations (never expose client-side)
# Find in: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=""
# Your Supabase project URL
# Find in: Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""
# Storage bucket names (create these in Supabase → Storage)
SUPABASE_STORAGE_BUCKET_CLIPART="clipart"
SUPABASE_STORAGE_BUCKET_DESIGNS="designs"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH="" # bcrypt hash of the admin password

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
