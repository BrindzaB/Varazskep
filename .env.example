# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ─── Database (Supabase) ─────────────────────────────────────────────────────
# DATABASE_URL: Transaction pooler (port 6543) — used by the app at runtime.
# Find in: Supabase → Connect → Transaction pooler URL
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# DIRECT_URL: Direct connection (port 5432) — used by Prisma CLI for migrations.
# Find in: Supabase → Connect → Direct connection URL
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-central-1"
AWS_S3_BUCKET_NAME=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH="" # bcrypt hash of the admin password

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
